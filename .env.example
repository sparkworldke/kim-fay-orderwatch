# Client-side API (browser) — local/dev direct to Laravel
VITE_API_BASE_URL=https://dating.sparkworld.co.ke/backend/public/api

# Production builds use .env.production (VITE_API_BASE_URL=/api, proxied by Cloudflare Worker).

# Server-side SSR auth validation — use HTTP locally to avoid self-signed cert errors in Node
VITE_API_BASE_URL_SSR=https://dating.sparkworld.co.ke/backend/public/api

# Set to false in dev if you must use HTTPS for SSR and have installed Laragon's CA in Node
# VITE_ALLOW_SELF_SIGNED_CERT=false
